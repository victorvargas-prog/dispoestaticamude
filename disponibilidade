    im=idxOf(H,['1. Impactos','Impactos']);
  const out=[];
  for(let i=h+1;i<rows.length;i++){const r=rows[i];const cod=norm(r[ic]);if(!cod)continue;
    let imp=null;
    if(im>=0){const raw=String(r[im]||'').replace(/\./g,'').replace(/,/g,'.').replace(/[^\d.]/g,'');
      const v=parseFloat(raw); imp=isNaN(v)?null:Math.round(v);}
    out.push({praca:p,cod,tipo:norm(r[it]),cidade:icid>=0?norm(r[icid]):CIDADE_FALLBACK[p]||'',
      bairro:norm(r[ib]),a:norm(r[ia]),b:norm(r[ibf]),coord:icoord>=0?norm(r[icoord]):'',imp});}
  if(!out.length) throw new Error('sem linhas');
  return out;
}

function scoped(){ return currentPraca ? STATIONS.filter(s=>s.praca===currentPraca) : STATIONS; }

function stats(list){
  let disp=0,occ=0,digi=0,full=0;
  list.forEach(s=>{const ca=classA(s),cb=classB(s);
    [ca,cb].forEach(c=>{if(c==='disp')disp++;else if(c==='digi')digi++;else occ++;});
    if(ca!=='disp'&&cb!=='disp') full++;});
  const sellable=disp+occ;
  return {n:list.length,faces:list.length*2,disp,occ,digi,full,occRate:sellable?Math.round(100*occ/sellable):0};
}

function renderPracaBar(){
  const counts={};PRACAS.forEach(p=>counts[p]=STATIONS.filter(s=>s.praca===p).length);
  const chips=[{p:'',label:'Todas'}].concat(PRACAS.map(p=>({p,label:p})));
  $('#pracaBar').innerHTML=chips.map(c=>{
    const n=c.p?counts[c.p]||0:STATIONS.length;
    return `<button class="ptab ${currentPraca===c.p?'active':''}" data-p="${c.p}">${c.label} <span class="n">${n}</span></button>`;
  }).join('');
  $$('.ptab').forEach(b=>b.addEventListener('click',()=>{currentPraca=b.dataset.p;renderAll();}));
}

function renderHead(){
  const list=scoped(); const s=stats(list);
  const cidade = currentPraca ? (CIDADE_FALLBACK[currentPraca] || currentPraca) : null;
  $('#eyebrow').textContent = currentPraca ? `MUBS OOH · Praça ${currentPraca}` : 'MUBS OOH · 2026 · Todas as praças';
  $('#h1').innerHTML = currentPraca ? `${cidade}` : `Mapa de <span>faces</span> estáticas`;
  $('#occ-big').textContent=s.occRate+'%';
  $('#hero-meta').innerHTML=`${s.n} estações · ${s.faces} faces · <b style="color:var(--accent)">${s.disp} estáticas disponíveis</b> · ${s.digi} digitais fora do cálculo`;
  const kp=[
    {n:s.n,k:'Estações'},
    {n:s.disp,k:'Faces estáticas disponíveis',c:'acc',bar:s.disp/(s.faces||1)},
    {n:s.occ,k:'Faces estáticas ocupadas',bar:s.occ/(s.faces||1)},
    {n:s.digi,k:'Faces digitais (Face A)',bar:s.digi/(s.faces||1)},
    {n:s.full,k:'Estações sem face livre',bar:s.full/(s.n||1)},
  ];
  $('#kpis').innerHTML=kp.map(k=>`<div class="kpi ${k.c||''}"><div class="n">${fmt(k.n)}</div><div class="k">${k.k}</div>
    ${k.bar!=null?`<div class="bar-strip"><i style="width:${(k.bar*100).toFixed(1)}%"></i></div>`:''}</div>`).join('');
}
function renderMural(){
  const list=scoped();
  $('#mural').innerHTML=list.map((s,i)=>{
    const ca=classA(s),cb=classB(s);
    const dim=(hidden[ca]&&hidden[cb])?'dim':'';
    return `<div class="gl ${dim}" data-i="${i}"><div class="fa f-${ca}"></div><div class="fb f-${cb}"></div></div>`;
  }).join('');
  window.__muralList=list;
}
const tip=$('#tip');
$('#mural').addEventListener('mousemove',e=>{
  const g=e.target.closest('.gl');if(!g){tip.style.opacity=0;return;}
  const s=window.__muralList[+g.dataset.i];
  tip.innerHTML=`<div class="tc">${s.cod}</div>
    <div class="tr"><span>${s.praca} · ${s.bairro}</span><b>${s.tipo}</b></div>
    <div class="tr"><span>Face A</span><b class="fpill">${s.a}</b></div>
    <div class="tr"><span>Face B</span><b class="fpill">${s.b}</b></div>
    <div class="tr"><span>Impactos/mês</span><b>${fmt(s.imp)}</b></div>`;
  tip.style.opacity=1;
  const r=tip.getBoundingClientRect();let x=e.clientX+14,y=e.clientY+14;
  if(x+r.width>innerWidth)x=e.clientX-r.width-14; if(y+r.height>innerHeight)y=e.clientY-r.height-14;
  tip.style.left=x+'px';tip.style.top=y+'px';
});
$('#mural').addEventListener('mouseleave',()=>tip.style.opacity=0);

function renderBairro(){
  const list=scoped();const g={};
  list.forEach(s=>{const b=s.bairro||'—';(g[b]=g[b]||{disp:0,occ:0,digi:0,est:0}).est++;
    [classA(s),classB(s)].forEach(c=>{g[b][c]++;});});
  const arr=Object.entries(g).map(([b,v])=>({b,...v,tot:v.disp+v.occ+v.digi})).sort((x,y)=>y.disp-x.disp||y.tot-x.tot);
  $('#bairro-note').textContent=arr.length+' bairros';
  $('#bairro-list').innerHTML=arr.length?arr.map(r=>`<div class="brow">
    <div class="bt"><span class="name">${r.b}</span><span class="val">${r.disp} disp · ${r.est} est.</span></div>
    <div class="track">
      <i class="seg-disp" style="width:${100*r.disp/r.tot}%"></i>
      <i class="seg-occ" style="width:${100*r.occ/r.tot}%"></i>
      <i class="seg-digi" style="width:${100*r.digi/r.tot}%"></i>
    </div></div>`).join(''):`<div class="empty">Sem dados.</div>`;
}
function renderTipo(){
  const list=scoped();const g={};
  list.forEach(s=>{const t=s.tipo||'—';g[t]=g[t]||{disp:0,occ:0,digi:0};
    [classA(s),classB(s)].forEach(c=>{g[t][c]++;});});
  const arr=Object.entries(g).map(([t,v])=>({t,...v,tot:v.disp+v.occ+v.digi})).sort((a,b)=>b.tot-a.tot);
  $('#tipo-list').innerHTML=arr.length?arr.map(r=>`<div class="brow">
    <div class="bt"><span class="name">${r.t}</span><span class="val">${r.tot} faces</span></div>
    <div class="track">
      <i class="seg-disp" style="width:${100*r.disp/r.tot}%"></i>
      <i class="seg-occ" style="width:${100*r.occ/r.tot}%"></i>
      <i class="seg-digi" style="width:${100*r.digi/r.tot}%"></i>
    </div></div>`).join(''):`<div class="empty">Sem dados.</div>`;
}
function renderAdv(){
  const list=scoped();const g={};
  list.forEach(s=>{[['a',classA(s)],['b',classB(s)]].forEach(([side,c])=>{
    if(c==='occ'){const k=norm(side==='a'?s.a:s.b);g[k]=(g[k]||0)+1;}});});
  const arr=Object.entries(g).sort((a,b)=>b[1]-a[1]).slice(0,25);const max=arr[0]?arr[0][1]:1;
  $('#adv-list').innerHTML=arr.length?arr.map(([k,v])=>`<div class="brow">
    <div class="bt"><span class="name">${k}</span><span class="val">${v}</span></div>
    <div class="track"><i class="bar-solid" style="width:${100*v/max}%"></i></div></div>`).join(''):`<div class="empty">Sem dados.</div>`;
}

/* ---------- tabela principal ---------- */
let sortKey='cod',sortDir=1;
function pill(v,c){return `<span class="pill ${c}"><span class="d"></span>${c==='disp'?'Disponível':c==='digi'?'Digital':v}</span>`;}
function renderTable(){
  const q=$('#q').value.toLowerCase(),fb=$('#fBairro').value,ft=$('#fTipo').value,fs=$('#fStatus').value;
  let rows=scoped().filter(s=>{
    if(q&&!(s.cod+s.bairro+s.tipo+s.praca).toLowerCase().includes(q))return false;
    if(fb&&s.bairro!==fb)return false;
    if(ft&&s.tipo!==ft)return false;
    const ca=classA(s),cb=classB(s);
    if(fs==='disp'&&!(ca==='disp'||cb==='disp'))return false;
    if(fs==='full'&&(ca==='disp'||cb==='disp'))return false;
    if(fs==='digi'&&!(ca==='digi'||cb==='digi'))return false;
    return true;});
  rows.sort((a,b)=>{let x=a[sortKey],y=b[sortKey];
    if(sortKey==='imp'){x=x??-1;y=y??-1;} else if(typeof x==='string'){x=x.toLowerCase();y=(y||'').toLowerCase();}
    return (x<y?-1:x>y?1:0)*sortDir;});
  const tb=$('#tbody');
  tb.innerHTML=rows.length?rows.map(s=>{const ca=classA(s),cb=classB(s);return `<tr>
    <td class="mono">${s.cod}</td><td class="mono">${s.praca}</td><td>${s.tipo}</td><td>${s.bairro}</td>
    <td>${pill(s.a,ca)}</td><td>${pill(s.b,cb)}</td><td class="mono" style="text-align:right">${fmt(s.imp)}</td>
  </tr>`;}).join(''):`<tr><td colspan="7" class="empty">Nenhuma estação corresponde a esses filtros.</td></tr>`;
  $('#tcount').textContent=`${rows.length} de ${scoped().length} estações`;
}
function fillFilters(){
  const list=scoped();
  const bs=[...new Set(list.map(s=>s.bairro))].filter(Boolean).sort();
  const ts=[...new Set(list.map(s=>s.tipo))].filter(Boolean).sort();
  const curB=$('#fBairro').value, curT=$('#fTipo').value;
  $('#fBairro').innerHTML='<option value="">Todos os bairros</option>'+bs.map(b=>`<option ${b===curB?'selected':''}>${b}</option>`).join('');
  $('#fTipo').innerHTML='<option value="">Todos os tipos</option>'+ts.map(t=>`<option ${t===curT?'selected':''}>${t}</option>`).join('');
}
function renderAll(){renderPracaBar();renderHead();renderMural();renderBairro();renderTipo();renderAdv();fillFilters();renderTable();
  $('#foot-time').textContent='Atualizado '+new Date().toLocaleString('pt-BR')+(LIVE_OK.size?` · sincronizado: ${[...LIVE_OK].join(', ')}`:' · snapshot local');}

/* ================= PÁGINA DE EXPORTAÇÃO ================= */
const EXP_COLS=[
  {k:'cod',   label:'Código'},
  {k:'praca', label:'Praça'},
  {k:'cidade',label:'Cidade'},
  {k:'tipo',  label:'Tipo de mídia'},
  {k:'bairro',label:'Bairro / Setor'},
  {k:'face',  label:'Face (A/B)'},
  {k:'faceStatus',label:'Status da face'},
  {k:'imp',   label:'Impactos/mês'},
  {k:'coord', label:'Coordenadas'},
];
let expPracas = new Set();   // vazio = usa a praça atual do dashboard (ou todas)
let expCols = new Set(EXP_COLS.map(c=>c.k));
let expFormat = 'csv';

function openExportPage(){
  expPracas = new Set(currentPraca ? [currentPraca] : []);
  renderExpPracas(); renderExpCols(); updateExpPreview();
  $('#expOverlay').classList.add('open');
}
function closeExportPage(){ $('#expOverlay').classList.remove('open'); }
$('#openExport').addEventListener('click',openExportPage);
$('#closeExport').addEventListener('click',closeExportPage);
$('#cancelExport').addEventListener('click',closeExportPage);

function renderExpPracas(){
  $('#expPracas').innerHTML=PRACAS.map(p=>
    `<button class="chip ${expPracas.has(p)?'on':''}" data-p="${p}">${p}</button>`).join('');
  $$('#expPracas .chip').forEach(c=>c.addEventListener('click',()=>{
    const p=c.dataset.p; expPracas.has(p)?expPracas.delete(p):expPracas.add(p);
    c.classList.toggle('on'); updateExpPreview();
  }));
}
$('#expPracasAll').addEventListener('click',()=>{
  if(expPracas.size===PRACAS.length) expPracas.clear(); else PRACAS.forEach(p=>expPracas.add(p));
  renderExpPracas(); updateExpPreview();
});
function renderExpCols(){
  $('#expCols').innerHTML=EXP_COLS.map(c=>
    `<label class="check-row"><input type="checkbox" data-c="${c.k}" ${expCols.has(c.k)?'checked':''}><span>${c.label}</span></label>`).join('');
  $$('#expCols input').forEach(i=>i.addEventListener('change',()=>{
    i.checked?expCols.add(i.dataset.c):expCols.delete(i.dataset.c); updateExpPreview();
  }));
}
$('#expColsAll').addEventListener('click',()=>{
  if(expCols.size===EXP_COLS.length) expCols.clear(); else EXP_COLS.forEach(c=>expCols.add(c.k));
  renderExpCols(); updateExpPreview();
});
$$('#expFormat .chip').forEach(b=>b.addEventListener('click',()=>{
  $$('#expFormat .chip').forEach(x=>x.classList.remove('on')); b.classList.add('on'); expFormat=b.dataset.fmt;
}));
document.querySelectorAll('input[name="expStatus"]').forEach(r=>r.addEventListener('change',updateExpPreview));

function buildExportRows(){
  const status = document.querySelector('input[name="expStatus"]:checked').value;
  const pracaSet = expPracas.size ? expPracas : new Set(currentPraca ? [currentPraca] : PRACAS);
  const base = STATIONS.filter(s=>pracaSet.has(s.praca));
  const out=[];
  base.forEach(s=>{
    const ca=classA(s), cb=classB(s);
    [['A',ca],['B',cb]].forEach(([face,c])=>{
      let include=false;
      if(status==='disp') include = c==='disp';
      else if(status==='occ') include = c==='occ';
      else if(status==='static') include = c!=='digi';
      else if(status==='all') include = true;
      if(!include) return;
      out.push({cod:s.cod,praca:s.praca,cidade:s.cidade,tipo:s.tipo,bairro:s.bairro,face,
        faceStatus:c==='disp'?'Disponível':c==='digi'?'Digital':'Ocupada',
        imp:s.imp,coord:s.coord});
    });
  });
  return out;
}
function updateExpPreview(){
  const rows=buildExportRows();
  const cols=EXP_COLS.filter(c=>expCols.has(c.k));
  $('#expCount').textContent=`${rows.length} linha${rows.length===1?'':'s'}`;
  $('#expPreviewHead').innerHTML=cols.map(c=>`<th>${c.label}</th>`).join('');
  $('#expPreviewBody').innerHTML=rows.slice(0,40).map(r=>
    `<tr>${cols.map(c=>`<td>${r[c.k]==null?'—':r[c.k]}</td>`).join('')}</tr>`).join('') ||
    `<tr><td style="padding:24px;color:var(--muted)">Nenhuma linha com esses filtros.</td></tr>`;
}
function csvEscape(v){v=String(v??'');if(/[",\n;]/.test(v))return '"'+v.replace(/"/g,'""')+'"';return v;}
function triggerDownload(content,mime,filename){
  const blob=new Blob([content],{type:mime}); const url=URL.createObjectURL(blob);
  const a=document.createElement('a'); a.href=url; a.download=filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
}
$('#doExportBtn').addEventListener('click',()=>{
  const rows=buildExportRows(); const cols=EXP_COLS.filter(c=>expCols.has(c.k));
  const pracaSet = expPracas.size ? [...expPracas] : (currentPraca?[currentPraca]:['todas']);
  const label = pracaSet.length===1?pracaSet[0]:'multiplas-pracas';
  const date=new Date().toISOString().slice(0,10);
  if(expFormat==='csv'){
    const lines=[cols.map(c=>c.label).join(';')];
    rows.forEach(r=>lines.push(cols.map(c=>csvEscape(r[c.k])).join(';')));
    triggerDownload('\uFEFF'+lines.join('\r\n'),'text/csv;charset=utf-8;',`inventario_${label}_${date}.csv`);
  } else {
    const slim=rows.map(r=>{const o={};cols.forEach(c=>o[c.label]=r[c.k]);return o;});
    triggerDownload(JSON.stringify(slim,null,2),'application/json',`inventario_${label}_${date}.json`);
  }
});

/* ---------- eventos globais ---------- */
['input','change'].forEach(ev=>{$('#q').addEventListener(ev,renderTable);
  ['#fBairro','#fTipo','#fStatus'].forEach(id=>$(id).addEventListener(ev,renderTable));});
$$('th[data-s]').forEach(th=>th.addEventListener('click',()=>{const k=th.dataset.s;
  if(sortKey===k)sortDir*=-1;else{sortKey=k;sortDir=1;}renderTable();}));
document.addEventListener('click',e=>{const l=e.target.closest('#legend .lg');if(!l)return;
  const f=l.dataset.f;hidden[f]=!hidden[f];l.classList.toggle('off',hidden[f]);renderMural();});
$('#theme').addEventListener('click',()=>{const cur=document.documentElement.getAttribute('data-theme');
  document.documentElement.setAttribute('data-theme',cur==='light'?'':'light');});

async function doRefresh(){
  const b=$('#refresh'); b.style.opacity=.5;
  const results=await Promise.allSettled(PRACAS.map(fetchPraca));
  let merged=[];
  results.forEach((res,i)=>{const p=PRACAS[i];
    if(res.status==='fulfilled'&&res.value.length){merged=merged.concat(res.value);LIVE_OK.add(p);}
    else{merged=merged.concat(SNAPSHOT.filter(s=>s.praca===p));}
  });
  if(merged.length){STATIONS=merged;}
  renderAll();
  b.style.opacity=1;
}
$('#refresh').addEventListener('click',doRefresh);

renderAll();
doRefresh();
setInterval(doRefresh,120000);
</script>
