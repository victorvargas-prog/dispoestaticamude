<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Disponibilidade · MUBS OOH — Todas as praças</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0d0d0f; --surface:#161619; --surface2:#1d1d21; --line:rgba(255,255,255,.09);
  --line2:rgba(255,255,255,.14); --text:#f5f5f6; --muted:#9a9aa2; --faint:#65656d;
  --accent:#ed1847; --accent-soft:rgba(237,24,71,.14); --occ:#3a3a42; --occ-txt:#c7c7cd;
  --digi:#5b5b63; --shadow:0 1px 0 rgba(255,255,255,.04) inset, 0 8px 30px rgba(0,0,0,.35);
}
[data-theme="light"]{
  --bg:#f3f2f0; --surface:#ffffff; --surface2:#f7f6f4; --line:rgba(0,0,0,.09);
  --line2:rgba(0,0,0,.16); --text:#141416; --muted:#5f5f66; --faint:#9a9aa0;
  --accent:#ed1847; --accent-soft:rgba(237,24,71,.10); --occ:#d9d8d4; --occ-txt:#3a3a40; --digi:#b8b6b1;
  --shadow:0 1px 0 rgba(0,0,0,.02) inset, 0 8px 24px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:Inter,system-ui,sans-serif;
  -webkit-font-smoothing:antialiased;line-height:1.5;transition:background .3s,color .3s}
.wrap{max-width:1280px;margin:0 auto;padding:0 20px 80px}
a{color:inherit}
header{position:sticky;top:0;z-index:40;background:color-mix(in srgb,var(--bg) 82%,transparent);
  backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.hd{max-width:1280px;margin:0 auto;padding:16px 20px;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
.brand{display:flex;align-items:baseline;gap:12px;flex:1;min-width:220px}
.logo{font-family:Oswald;font-weight:700;font-size:22px;letter-spacing:.5px;text-transform:uppercase}
.logo .dot{color:var(--accent)}
.sub{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted)}
.hd-actions{display:flex;align-items:center;gap:10px}
.btn{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;
  background:var(--surface);border:1px solid var(--line2);color:var(--text);padding:9px 14px;border-radius:8px;
  cursor:pointer;transition:.15s;display:inline-flex;align-items:center;gap:7px;white-space:nowrap}
.btn:hover{border-color:var(--accent);color:var(--accent)}
.btn.primary{background:var(--accent);border-color:var(--accent);color:#fff}
.btn.primary:hover{opacity:.88;color:#fff}
.btn.ghost{background:transparent}
.btn:disabled{opacity:.4;cursor:not-allowed}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 0 var(--accent);animation:pulse 2s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(237,24,71,.5)}70%{box-shadow:0 0 0 7px rgba(237,24,71,0)}100%{box-shadow:0 0 0 0 rgba(237,24,71,0)}}
.praca-bar{display:flex;gap:8px;flex-wrap:wrap;padding:16px 0 0}
.ptab{font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.5px;background:var(--surface);
  border:1px solid var(--line);color:var(--muted);padding:9px 15px;border-radius:9px;cursor:pointer;transition:.15s;
  display:flex;align-items:center;gap:8px}
.ptab:hover{border-color:var(--line2);color:var(--text)}
.ptab.active{background:var(--accent);border-color:var(--accent);color:#fff}
.ptab .n{opacity:.65;font-size:10.5px}
.ptab.active .n{opacity:.85}
.hero{padding:30px 0 26px;display:flex;justify-content:space-between;align-items:flex-end;gap:30px;flex-wrap:wrap}
.hero .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
.hero h1{font-family:Oswald;font-weight:600;font-size:clamp(28px,4.6vw,48px);line-height:1;letter-spacing:-.5px;text-transform:uppercase}
.hero h1 span{color:var(--faint)}
.hero .meta{font-size:13px;color:var(--muted);margin-top:12px;font-family:'IBM Plex Mono',monospace}
.occ-badge{text-align:right}
.occ-badge .big{font-family:Oswald;font-weight:700;font-size:clamp(40px,8vw,76px);line-height:.85;color:var(--accent)}
.occ-badge .lbl{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-top:6px}
.kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin:14px 0 46px}
.kpi{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:20px 18px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.kpi .n{font-family:Oswald;font-weight:600;font-size:38px;line-height:1;letter-spacing:-1px}
.kpi .k{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);margin-top:9px}
.kpi.acc .n{color:var(--accent)}
.kpi .bar-strip{position:absolute;left:0;bottom:0;height:3px;width:100%;background:var(--line)}
.kpi .bar-strip i{display:block;height:100%;background:var(--accent)}
.sec{margin:52px 0 0}
.sec-hd{display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:22px;flex-wrap:wrap}
.sec-hd h2{font-family:Oswald;font-weight:500;font-size:24px;text-transform:uppercase;letter-spacing:.3px;display:flex;align-items:center;gap:12px}
.sec-hd h2 .idx{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent);font-weight:500}
.sec-hd p{font-size:13px;color:var(--muted);max-width:460px}
.legend{display:flex;gap:8px;flex-wrap:wrap}
.lg{display:inline-flex;align-items:center;gap:8px;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.5px;text-transform:uppercase;
  color:var(--muted);background:var(--surface);border:1px solid var(--line);padding:7px 11px;border-radius:20px;cursor:pointer;transition:.15s;user-select:none}
.lg:hover{border-color:var(--line2)}
.lg.off{opacity:.34}
.sw{width:12px;height:12px;border-radius:3px;flex:none}
.sw.disp{background:var(--accent)}
.sw.occ{background:var(--occ)}
.sw.digi{background:repeating-linear-gradient(-45deg,var(--text),var(--text) 2px,transparent 2px,transparent 4px);border:1px solid var(--line2)}
.mural-wrap{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:8px;box-shadow:var(--shadow)}
.mural{display:grid;grid-template-columns:repeat(auto-fill,minmax(26px,1fr));gap:5px;padding:16px;max-height:560px;overflow-y:auto}
.gl{aspect-ratio:1/1.7;border-radius:5px;overflow:hidden;display:flex;flex-direction:column;cursor:pointer;
  border:1px solid var(--line);transition:transform .12s,box-shadow .12s;background:var(--surface2);position:relative}
.gl:hover{transform:translateY(-3px) scale(1.08);box-shadow:0 6px 18px rgba(0,0,0,.4);z-index:5;border-color:var(--line2)}
.gl .fa,.gl .fb{flex:1;position:relative}
.gl .fa{border-bottom:1px solid rgba(0,0,0,.35)}
.f-disp{background:var(--accent)}
.f-occ{background:var(--occ)}
.f-digi{background:var(--surface2);background-image:repeating-linear-gradient(0deg,rgba(255,255,255,.14) 0,rgba(255,255,255,.14) 1px,transparent 1px,transparent 3px)}
[data-theme="light"] .f-digi{background-image:repeating-linear-gradient(0deg,rgba(0,0,0,.16) 0,rgba(0,0,0,.16) 1px,transparent 1px,transparent 3px)}
.gl.dim{opacity:.12;filter:grayscale(1)}
#tip{position:fixed;z-index:100;pointer-events:none;background:var(--surface);border:1px solid var(--line2);
  border-radius:10px;padding:11px 13px;font-size:12px;box-shadow:0 10px 30px rgba(0,0,0,.5);opacity:0;transition:opacity .1s;max-width:230px}
#tip .tc{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:13px;margin-bottom:5px}
#tip .tr{display:flex;justify-content:space-between;gap:14px;color:var(--muted);font-size:11.5px;padding:1px 0}
#tip .tr b{color:var(--text);font-weight:600}
#tip .fpill{font-family:'IBM Plex Mono',monospace}
.two{display:grid;grid-template-columns:1fr 1fr;gap:26px}
.card{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:24px;box-shadow:var(--shadow)}
.card h3{font-family:Oswald;font-weight:500;font-size:18px;text-transform:uppercase;letter-spacing:.3px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:baseline}
.card h3 small{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--faint);text-transform:none;letter-spacing:0}
.blist{display:flex;flex-direction:column;gap:13px;max-height:360px;overflow-y:auto;padding-right:4px}
.brow .bt{display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;gap:10px}
.brow .bt .name{color:var(--text);font-weight:500}
.brow .bt .val{font-family:'IBM Plex Mono',monospace;color:var(--muted);white-space:nowrap}
.track{height:9px;background:var(--surface2);border-radius:6px;overflow:hidden;display:flex}
.track i{height:100%;display:block}
.seg-disp{background:var(--accent)}
.seg-occ{background:var(--occ)}
.seg-digi{background:var(--line2)}
.bar-solid{background:var(--accent)}
.controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.controls input,.controls select{font-family:Inter;font-size:13px;background:var(--surface);border:1px solid var(--line2);
  color:var(--text);padding:10px 13px;border-radius:9px;outline:none}
.controls input{flex:1;min-width:180px}
.controls input:focus,.controls select:focus{border-color:var(--accent)}
.tbl-wrap{background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:var(--shadow)}
.tbl-scroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px;min-width:760px}
th{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);
  text-align:left;padding:14px 16px;border-bottom:1px solid var(--line2);cursor:pointer;user-select:none;white-space:nowrap}
th:hover{color:var(--accent)}
td{padding:12px 16px;border-bottom:1px solid var(--line);white-space:nowrap}
tr:last-child td{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
.mono{font-family:'IBM Plex Mono',monospace;font-size:12px}
.pill{display:inline-flex;align-items:center;gap:6px;font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.5px;
  padding:3px 9px;border-radius:20px;border:1px solid var(--line2);white-space:nowrap}
.pill.disp{color:var(--accent);border-color:var(--accent);background:var(--accent-soft)}
.pill.occ{color:var(--occ-txt)}
.pill.digi{color:var(--text)}
.pill .d{width:7px;height:7px;border-radius:2px}
.pill.disp .d{background:var(--accent)}
.pill.occ .d{background:var(--occ)}
.pill.digi .d{background:repeating-linear-gradient(-45deg,currentColor,currentColor 2px,transparent 2px,transparent 4px)}
.empty{padding:50px;text-align:center;color:var(--muted);font-size:14px}
.count-note{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--faint);margin-top:12px;text-align:right}
footer{margin-top:60px;padding-top:24px;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;
  font-size:11px;color:var(--faint);letter-spacing:.5px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}
@media(max-width:820px){.kpis{grid-template-columns:repeat(2,1fr)}.two{grid-template-columns:1fr}.hero{align-items:flex-start}.occ-badge{text-align:left}}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}

/* ---------- EXPORT PAGE (overlay) ---------- */
.exp-overlay{position:fixed;inset:0;z-index:200;background:var(--bg);overflow-y:auto;display:none}
.exp-overlay.open{display:block}
.exp-hd{position:sticky;top:0;background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(14px);
  border-bottom:1px solid var(--line);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;z-index:5}
.exp-hd .t{font-family:Oswald;font-weight:600;font-size:20px;text-transform:uppercase;letter-spacing:.3px}
.exp-body{max-width:980px;margin:0 auto;padding:34px 20px 100px;display:grid;gap:26px}
.exp-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px}
.exp-card{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:24px;box-shadow:var(--shadow)}
.exp-card h4{font-family:Oswald;font-weight:500;font-size:15px;text-transform:uppercase;letter-spacing:.4px;margin-bottom:16px;color:var(--muted)}
.chip-grid{display:flex;flex-wrap:wrap;gap:8px}
.chip{font-family:'IBM Plex Mono',monospace;font-size:11.5px;background:var(--surface2);border:1px solid var(--line2);
  color:var(--muted);padding:8px 13px;border-radius:20px;cursor:pointer;transition:.15s;user-select:none}
.chip.on{background:var(--accent);border-color:var(--accent);color:#fff}
.radio-row,.check-row{display:flex;align-items:center;gap:10px;padding:9px 0;font-size:13.5px;cursor:pointer}
.radio-row input,.check-row input{width:16px;height:16px;accent-color:var(--accent);cursor:pointer}
.radio-row span small,.check-row span small{display:block;color:var(--faint);font-size:11.5px;font-weight:400;margin-top:1px}
.col-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px 18px}
.exp-preview{background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:var(--shadow)}
.exp-preview .ph{padding:16px 20px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
.exp-preview .ph b{font-family:Oswald;font-size:15px;text-transform:uppercase;letter-spacing:.3px}
.exp-preview .ph .cnt{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent)}
.exp-table-wrap{overflow-x:auto;max-height:340px;overflow-y:auto}
.exp-table-wrap table{width:100%;font-size:12.5px;border-collapse:collapse;min-width:600px}
.exp-table-wrap th{position:sticky;top:0;background:var(--surface);font-family:'IBM Plex Mono',monospace;font-size:10px;
  text-transform:uppercase;letter-spacing:.7px;color:var(--muted);padding:10px 14px;text-align:left;border-bottom:1px solid var(--line2)}
.exp-table-wrap td{padding:9px 14px;border-bottom:1px solid var(--line);white-space:nowrap;font-family:'IBM Plex Mono',monospace;font-size:12px}
.exp-footer-bar{position:sticky;bottom:0;background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(14px);
  border-top:1px solid var(--line);padding:16px 20px;display:flex;justify-content:flex-end;gap:10px}
.fmt-row{display:flex;gap:8px}
.select-all{font-size:11.5px;color:var(--accent);cursor:pointer;font-family:'IBM Plex Mono',monospace;letter-spacing:.5px}
</style>
</head>
<body>
<header>
  <div class="hd">
    <div class="brand">
      <div class="logo">MUDE<span class="dot">.</span></div>
      <div class="sub">Disponibilidade OOH · faces estáticas</div>
    </div>
    <div class="hd-actions">
      <button class="btn" id="refresh"><span class="sync-dot"></span> Atualizar</button>
      <button class="btn primary" id="openExport">⭳ Exportar</button>
      <button class="btn" id="theme">Tema</button>
    </div>
  </div>
  <div class="wrap"><div class="praca-bar" id="pracaBar"></div></div>
</header>
<div class="wrap">
  <section class="hero">
    <div>
      <div class="eyebrow" id="eyebrow">MUBS OOH · 2026</div>
      <h1 id="h1">Todas as <span>praças</span></h1>
      <div class="meta" id="hero-meta">carregando…</div>
    </div>
    <div class="occ-badge">
      <div class="big" id="occ-big">—</div>
      <div class="lbl">Ocupação estática</div>
    </div>
  </section>

  <div class="kpis" id="kpis"></div>

  <section class="sec">
    <div class="sec-hd">
      <div>
        <h2><span class="idx">01</span> Mural de faces estáticas</h2>
        <p>Cada totem é uma estação. Faces digitais aparecem hachuradas e ficam fora do cálculo de disponibilidade.</p>
      </div>
      <div class="legend" id="legend">
        <span class="lg" data-f="disp"><span class="sw disp"></span> Disponível</span>
        <span class="lg" data-f="occ"><span class="sw occ"></span> Ocupada</span>
        <span class="lg" data-f="digi"><span class="sw digi"></span> Digital (fora do cálculo)</span>
      </div>
    </div>
    <div class="mural-wrap"><div class="mural" id="mural"></div></div>
  </section>

  <section class="sec two">
    <div class="card">
      <h3>Disponibilidade por bairro <small id="bairro-note"></small></h3>
      <div class="blist" id="bairro-list"></div>
    </div>
    <div>
      <div class="card" style="margin-bottom:26px">
        <h3>Faces estáticas por tipo</h3>
        <div class="blist" id="tipo-list"></div>
      </div>
      <div class="card">
        <h3>Ocupação por anunciante <small>faces estáticas vendidas</small></h3>
        <div class="blist" id="adv-list"></div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="sec-hd">
      <div><h2><span class="idx">02</span> Inventário</h2></div>
    </div>
    <div class="controls">
      <input type="text" id="q" placeholder="Buscar por código, unidade ou bairro…">
      <select id="fBairro"><option value="">Todos os bairros</option></select>
      <select id="fTipo"><option value="">Todos os tipos</option></select>
      <select id="fStatus">
        <option value="">Qualquer status</option>
        <option value="disp">Com face estática disponível</option>
        <option value="full">Totalmente ocupada (estática)</option>
        <option value="digi">Possui face digital</option>
      </select>
    </div>
    <div class="tbl-wrap"><div class="tbl-scroll">
      <table>
        <thead><tr>
          <th data-s="cod">Código</th><th data-s="praca">Praça</th><th data-s="tipo">Tipo</th><th data-s="bairro">Bairro / Setor</th>
          <th data-s="a">Face A</th><th data-s="b">Face B</th><th data-s="imp" style="text-align:right">Impactos/mês</th>
        </tr></thead>
        <tbody id="tbody"></tbody>
      </table>
    </div></div>
    <div class="count-note" id="tcount"></div>
  </section>

  <footer>
    <span>Fonte: planilha DISPONIBILIDADE MUBS OOH GERAL — OPEC · sincronização automática por aba</span>
    <span id="foot-time"></span>
  </footer>
</div>
<div id="tip"></div>

<!-- ================= EXPORT OVERLAY ================= -->
<div class="exp-overlay" id="expOverlay">
  <div class="exp-hd">
    <div class="t">Exportar inventário</div>
    <button class="btn ghost" id="closeExport">✕ Fechar</button>
  </div>
  <div class="exp-body">
    <div class="exp-grid">
      <div class="exp-card">
        <h4>Praças</h4>
        <div class="chip-grid" id="expPracas"></div>
        <div class="select-all" id="expPracasAll" style="margin-top:12px">selecionar todas</div>
      </div>
      <div class="exp-card">
        <h4>Quais faces incluir</h4>
        <label class="radio-row"><input type="radio" name="expStatus" value="disp" checked>
          <span>Somente disponíveis <small>faces estáticas livres para venda</small></span></label>
        <label class="radio-row"><input type="radio" name="expStatus" value="occ">
          <span>Somente ocupadas <small>faces estáticas com anunciante</small></span></label>
        <label class="radio-row"><input type="radio" name="expStatus" value="static">
          <span>Todas as estáticas <small>disponíveis + ocupadas, sem digitais</small></span></label>
        <label class="radio-row"><input type="radio" name="expStatus" value="all">
          <span>Tudo <small>inclui faces digitais também</small></span></label>
      </div>
    </div>

    <div class="exp-card">
      <h4>Colunas do arquivo</h4>
      <div class="col-grid" id="expCols"></div>
      <div class="select-all" id="expColsAll" style="margin-top:10px">selecionar todas</div>
    </div>

    <div class="exp-card">
      <h4>Formato</h4>
      <div class="fmt-row" id="expFormat">
        <button class="chip on" data-fmt="csv">CSV (Excel)</button>
        <button class="chip" data-fmt="json">JSON</button>
      </div>
    </div>

    <div class="exp-preview">
      <div class="ph"><b>Pré-visualização</b><span class="cnt" id="expCount">0 linhas</span></div>
      <div class="exp-table-wrap"><table><thead><tr id="expPreviewHead"></tr></thead><tbody id="expPreviewBody"></tbody></table></div>
    </div>
  </div>
  <div class="exp-footer-bar">
    <button class="btn" id="cancelExport">Cancelar</button>
    <button class="btn primary" id="doExportBtn">⭳ Baixar arquivo</button>
  </div>
</div>

<script>
